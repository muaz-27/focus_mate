<?xml version="1.0" encoding="utf-8"?>
<!-- Android 12+ splash screen API — matches our Flutter splash dark theme -->
<resources>
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowFullscreen">true</item>
        <!-- Android 12+ Splash Screen attributes -->
        <item name="android:windowSplashScreenBackground">#060D1F</item>
        <item name="android:windowSplashScreenAnimationDuration">300</item>
    </style>
    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowFullscreen">true</item>
    </style>
</resources>
